# ai-agents — user credentials
#
# Place this file at: ~/.copilot/.env
#
# Scripts load credentials from ~/.copilot/.env automatically.
# This file is never committed — each user has their own copy.
# ─────────────────────────────────────────

JIRA_BASE_URL=https://ascend-learning.atlassian.net
JIRA_USER_EMAIL=your.email@ascendlearning.com
JIRA_API_TOKEN=your_api_token_here
JIRA_PROJECT_KEY=AMBS
# Comma-separated Jira labels added to tickets you create (e.g. your username/team tag)
JIRA_LABELS=your-label-here
GITLAB_BASE_URL=https://git.ascendlearning.com
GITLAB_TOKEN=your_gitlab_token_here

# Optional: override where investigation workspaces are stored.
# Defaults to docs/ambs-investigations/ inside the current project — no configuration needed.
# INVESTIGATIONS_ROOT=/path/to/custom/investigations
